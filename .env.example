# 数据库配置（Docker 内外通用）
# Linux Docker 使用 172.17.0.1 或 host.docker.internal
# Windows/Mac Docker 使用 host.docker.internal
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=agent_memory
DB_USER=postgres
DB_PASSWORD=123456

# API 密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 模型配置
MODEL_ID=deepseek/deepseek-reasoner

# 可选：直接指定完整数据库 URL（优先级高于上面的配置）
# DATABASE_URL=postgresql+asyncpg://postgres:123456@host.docker.internal:5432/agent_memory

# ============================================
# Skill Engine Configuration
# ============================================

# Master switch for Skill Engine (default: true)
# SKILL_ENGINE_ENABLED=true

# Embedding configuration (default: false for Phase 1 rollout)
# SKILL_EMBEDDING_ENABLED=false
# SKILL_EMBEDDING_MODEL=openai/text-embedding-3-small

# OpenAI API key (required for embedding)
# OPENAI_API_KEY=your_openai_api_key_here

# Two-phase execution (default: false for Phase 1 rollout)
# SKILL_TWO_PHASE_ENABLED=false
# SKILL_CLEANUP_WORKSPACE=true

# Quality tracking (default: true)
# SKILL_QUALITY_ENABLED=true
# SKILL_QUALITY_FILTER_PROBLEMATIC=false

# Emergency disable (set to 'true' to completely disable Skill Engine)
# SKILL_ENGINE_EMERGENCY_DISABLE=false
