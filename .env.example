# =============================================================================
# API Keys - Configure one or more providers
# At least one API key must be configured
# =============================================================================

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT) - https://platform.openai.com/
OPENAI_API_KEY=sk-openai-xxx

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-deepseek-xxx

# Moonshot Kimi - https://platform.moonshot.cn/
KIMI_API_KEY=sk-kimi-xxx

# =============================================================================
# Optional: Provider-specific Base URLs
# Only set if using a proxy or custom endpoint
# =============================================================================
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# =============================================================================
# Model Configuration (Unified Configuration System)
# =============================================================================
# The system uses ProviderManager as the single source of truth for model config.
#
# Configuration Priority (highest to lowest):
# 1. MODEL_ID - Primary model identifier (recommended)
# 2. PROVIDER_MODEL - Provider-specific variable (e.g., ANTHROPIC_MODEL, DEEPSEEK_MODEL)
# 3. Inferred default based on available API key
#
# Examples:
#   MODEL_ID=claude-sonnet-4-6      # Anthropic Claude
#   MODEL_ID=gpt-4o                 # OpenAI GPT-4o
#   MODEL_ID=deepseek/deepseek-chat # DeepSeek
#   MODEL_ID=kimi-k2-coding         # Moonshot Kimi
#
# Note: If MODEL_ID is not set, the system will infer a default based on
# which API key is available (ANTHROPIC_API_KEY -> Claude, OPENAI_API_KEY -> GPT-4o, etc.)
# =============================================================================
MODEL_ID=claude-sonnet-4-6

# (Optional) Provider-specific model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
# DEEPSEEK_MODEL=deepseek/deepseek-chat
# KIMI_MODEL=kimi-k2-coding

# Agent Sandbox Mode (optional)
# local = use host shell directly (default)
# docker = use Docker container for isolated tool/shell execution
# AGENT_SANDBOX=local

# Database Configuration (for finance skill)
# When using AGENT_SANDBOX=docker, use host.docker.internal to reach the host PostgreSQL
# or the docker-compose PostgreSQL service exposed on port 5432
# DB_HOST=host.docker.internal
# DB_NAME=cost_allocation
# DB_USER=postgres
# DB_PASSWORD=123456
# DB_PORT=5432

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
#  Anthropic-compatible providers
#
#  Provider         MODEL_ID              SWE-bench  TB2     Base URL
#  ---------------  --------------------  ---------  ------  -------------------
#  Anthropic        claude-sonnet-4-6     79.6%      59.1%   (default)
#  MiniMax          MiniMax-M2.5          80.2%        -     see below
#  GLM (Zhipu)      glm-5                77.8%        -     see below
#  Kimi (Moonshot)  kimi-k2.5            76.8%        -     see below
#  DeepSeek         deepseek-chat        73.0%        -     see below
#                   (V3.2)
#
#  SWE-bench = SWE-bench Verified (Feb 2026)
#  TB2       = Terminal-Bench 2.0 (Feb 2026)
# =============================================================================

# ---- International ----

# MiniMax          https://www.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://z.ai
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://platform.moonshot.ai
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek         https://platform.deepseek.com
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# ---- China mainland ----

# MiniMax          https://platform.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://open.bigmodel.cn
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://platform.moonshot.cn
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek (no regional split, same endpoint globally)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# Finance SQL skill (required for sql_query)
DB_NAME=your_database_name
DB_SERVER=your_sql_server_host
DB_PORT=1433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DRIVER=SQL Server

# bash executable script whitelist (semicolon-separated)
# Supports directory entries (e.g. .workspace) and wildcard rule skills/**/scripts
BASH_SCRIPT_WHITELIST=.workspace;skills/**/scripts

# write/edit tool whitelist (semicolon-separated)
# Relative paths are auto-prefixed to the first whitelist path.
WRITE_TOOL_WHITELIST=.workspace
EDIT_TOOL_WHITELIST=.workspace

# read tool blacklist (semicolon-separated)
# Default blocks reading .env while allowing other workspace files.
READ_TOOL_BLACKLIST=.env
